# ─── Google BigQuery ──────────────────────────────────────────────────────────
# Path to your GCP service account JSON key file (relative to project root)
GOOGLE_APPLICATION_CREDENTIALS=starlit-link-475400-s5-9b1224eed9dd.json

GCP_PROJECT_ID=starlit-link-475400-s5
BQ_DATASET=l11_stw

# ─── BQ snapshot cache (optional — speeds up /phonebanking/[tag]) ─────────────
# Persist BigQuery results for dates before "yesterday" (America/Los_Angeles).
# Recent ~3 LA calendar days always query BigQuery. Set a secret to enable the
# on-page "Rebuild history" panel and POST /api/phonebanking/bq-snapshot-refresh
# CAMPAIGN_DASHBOARD_SNAPSHOT_SECRET=your-long-random-string
# BQ_SNAPSHOTS_DISABLED=1   # force every request to hit BigQuery (debug)

# Optional: short-lived in-memory cache for identical BQ reads (seconds)
# CAMPAIGN_DASHBOARD_BQ_CACHE_SECONDS=45

# ─── PDI Tools (mapper live refresh + optional paths) ─────────────────────────
# PDI_USERNAME=...
# PDI_PASSWORD=...
# PDI_API_TOKEN=...
# PDI_TOOLS_DATA_DIR=C:\path\to\folder-with-ndjson   # optional; else ../pdiv3 or ../MoonDough
# PDI_STW_TO_PDI_SCRIPT=C:\path\to\pdiv3\stw_to_pdi.py
# PDI_MAPPINGS_DIR=C:\path\to\custom\pdi-mappings
# PDI_SYNC_EXPORTS_DIR=C:\path\to\custom\pdi-sync-exports
# PDI_STW_WORKING_DIR=C:\path\to\pdiv3
# PYTHON_EXECUTABLE=python
# PDI_SYNC_ENGINE=python   # omit or any value except python → native TS sync + live logs

# ─── Campaign Tags ────────────────────────────────────────────────────────────
# Comma-separated list of candidate tag IDs defined in lib/campaign-tags.ts
# The app reads from the static config, this is just for reference.

# ─── Setup Instructions ───────────────────────────────────────────────────────
# 1. Copy this file to .env.local:
#      cp .env.local.example .env.local
# 2. Fill in your real credentials above
# 3. Place your GCP service account JSON key in the project root
#    (the filename must match GOOGLE_APPLICATION_CREDENTIALS above)
