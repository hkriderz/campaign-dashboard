# Copy to .env.local (dev) or set in Dokploy environment variables (production).

# ─── Google BigQuery ───────────────────────────────────────────────────────────
# Option A: path to service account JSON (relative to project root or absolute)
# GOOGLE_APPLICATION_CREDENTIALS=credentials/gcp-service-account.json

# Option B (Docker/VPS): paste full JSON or base64-encoded JSON — written at startup
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

GCP_PROJECT_ID=your-gcp-project-id
BQ_DATASET=l11_stw

# ─── Optional: persistent data directory (mount a volume here on Dokploy) ───
# CAMPAIGN_DASHBOARD_DATA_DIR=/app

# ─── BQ snapshot cache ───────────────────────────────────────────────────────
# CAMPAIGN_DASHBOARD_SNAPSHOT_SECRET=your-long-random-string
# BQ_SNAPSHOTS_DISABLED=1
# CAMPAIGN_DASHBOARD_BQ_CACHE_SECONDS=45
# CAMPAIGN_DASHBOARD_MERGED_BQ_CACHE_SECONDS=120

# ─── PDI Tools (optional — or use credentials/ uploads in the UI) ─────────────
# PDI_USERNAME=
# PDI_PASSWORD=
# PDI_API_TOKEN=
# PDI_TOOLS_DATA_DIR=/path/to/ndjson-folder
# PDI_SYNC_ENGINE=typescript

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOSTNAME=0.0.0.0
